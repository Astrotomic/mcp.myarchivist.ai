{
    "name": "astrotomic/mcp.myarchivist.ai",
    "description": "",
    "license": "MIT",
    "type": "project",
    "keywords": [],
    "require": {
        "php": "^8.4",
        "laravel/framework": "^13.11.2",
        "laravel/mcp": "^0.7.1",
        "sentry/sentry-laravel": "^4.25.1"
    },
    "require-dev": {
        "fakerphp/faker": "^1.24.1",
        "larastan/larastan": "^3.9.6",
        "laravel/pint": "^1.29.1",
        "laravel/tinker": "^3.0.2",
        "mockery/mockery": "^1.6.12",
        "nunomaduro/collision": "^8.9.4",
        "phpstan/extension-installer": "^1.4.3",
        "phpstan/phpstan-deprecation-rules": "^2.0.4",
        "phpunit/phpunit": "^12.5.25",
        "povils/phpmnd": "^3.6.1",
        "spatie/phpunit-snapshot-assertions": "^5.4",
        "spaze/phpstan-disallowed-calls": "^4.12"
    },
    "minimum-stability": "stable",
    "prefer-stable": true,
    "autoload": {
        "psr-4": {
            "App\\": "app/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Astrotomic\\PHPStan\\": "phpstan/",
            "Tests\\": "tests/"
        }
    },
    "config": {
        "allow-plugins": {
            "pestphp/pest-plugin": true,
            "php-http/discovery": true,
            "phpstan/extension-installer": true
        },
        "optimize-autoloader": true,
        "preferred-install": "dist",
        "sort-packages": true
    },
    "extra": {
        "laravel": {
            "dont-discover": []
        }
    },
    "scripts": {
        "post-update-cmd": [
            "@php artisan vendor:publish --tag=laravel-assets --ansi --force"
        ],
        "pre-package-uninstall": [
            "Illuminate\\Foundation\\ComposerScripts::prePackageUninstall"
        ],
        "post-autoload-dump": [
            "Illuminate\\Foundation\\ComposerScripts::postAutoloadDump",
            "@php artisan package:discover --ansi"
        ],
        "post-root-package-install": [
            "@php -r \"file_exists('.env') || copy('.env.example', '.env');\""
        ],
        "post-create-project-cmd": [
            "@php artisan key:generate --ansi"
        ],
        "dev": "@php artisan serve",
        "fix": "@php vendor/bin/pint",
        "fix-dirty": "@php vendor/bin/pint --dirty",
        "lint": "@php vendor/bin/pint --test",
        "normalize": "echo 'composer global require ergebnis/composer-normalize'",
        "phpstan": "@php vendor/bin/phpstan analyse --memory-limit=2G",
        "phpstan-baseline": "@php vendor/bin/phpstan analyse --memory-limit=2G --allow-empty-baseline --generate-baseline",
        "phpstan-ci": "@php vendor/bin/phpstan analyse --no-progress --error-format gitlab --memory-limit=4G -vv",
        "test": "@php artisan test"
    },
    "$schema": "https://getcomposer.org/schema.json"
}
